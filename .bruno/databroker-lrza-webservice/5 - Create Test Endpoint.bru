meta {
  name: 5 - Create Test Endpoint
  type: http
  seq: 6
}

post {
  url: http://localhost:8080/Endpoint
  body: json
  auth: inherit
}

body:json {
  {
    "endpointIdentifier": "urn:uuid:{{$randomUUID}}",
    "endpointName": "<name-of-endpoint>",
    "addressUrl": "<url-of-endpoint>",
    "vendorId": "<fhir-ref-to-it-vendor>",
    "connectionType": {
      "system": "http://terminology.hl7.org/CodeSystem/endpoint-connection-type",
      "code": "hl7-fhir-rest"
    },
    "payloadType": {
      "system": "http://nuts-foundation.github.io/nl-generic-functions-ig/CodeSystem/nl-gf-data-exchange-capabilities",
      "code": "http://nictiz.nl/fhir/CapabilityStatement/bgz2017-servercapabilities"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
